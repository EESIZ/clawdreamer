# ── Embedding Provider ──
# Options: "openai" (default), "ollama", "sentence-transformers"
DREAMER_EMBEDDING_PROVIDER=openai

# OpenAI (required if provider=openai)
OPENAI_API_KEY=sk-...

# Ollama (required if provider=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Sentence-transformers (required if provider=sentence-transformers)
# ST_MODEL_NAME=all-MiniLM-L6-v2

# Vector dimension (must match your embedding model)
# openai/text-embedding-3-small=1536, nomic-embed-text=768, all-MiniLM-L6-v2=384
# DREAMER_EMBEDDING_DIM=1536

# ── LLM Provider ──
# Options: "openai" (default), "ollama", "minimax"
DREAMER_LLM_PROVIDER=openai

# Ollama LLM (if provider=ollama)
# OLLAMA_LLM_MODEL=qwen2.5:3b

# MiniMax (if provider=minimax)
# MINIMAX_API_KEY=

# ── Data Directory ──
# DREAMER_HOME=~/.dreamer
